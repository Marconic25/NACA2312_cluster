FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      sample;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

type            sets;
libs            ("libsampling.so");

interpolationScheme cellPoint;

setFormat       raw;

sets
(
    chordLine
    {
        type        lineUniform;
        axis        x;
        start       (0.01  0  0.125);
        end         (0.99  0  0.125);
        nPoints     500;
    }
);

fields          (p);

