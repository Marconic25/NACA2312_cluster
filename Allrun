#!/bin/bash

#------------------------------------------------------------------------------
# Allrun — NACA2312 Co-simulation
# Stage 1 (snappyHexMesh) : skip se mesh presente in rans_baseline
# Stage 2 (simpleFoam)    : skip se latestTime > 0 presente in rans_baseline
# Stage 3 (pimpleFoam)    : sempre eseguito (cosim_main)
# Stage 4 (post-proc)     : reconstructPar + plot (cosim_main)
#------------------------------------------------------------------------------

set -e

CONTAINER_ABS="/work/u10677113/of7.sif"
WRAPPER_DIR="$HOME/bin_of7"
WORKDIR="/work/u10677113/NACA2312"

#------------------------------------------------------------------------------
# FUNZIONI
#------------------------------------------------------------------------------

runApplication() {
    local APP="$1"
    shift
    local CURRENT_DIR
    CURRENT_DIR="$(pwd -P)"
    echo "--- Running $APP $@ ---"
    apptainer exec "$CONTAINER_ABS" /bin/bash -c \
        "source /opt/openfoam7/etc/bashrc && cd ${CURRENT_DIR} && $APP $*" \
        2>&1 | tee "log.$APP"
}

latestTime() {
    local DIR="${1:-.}"
    find "$DIR" -maxdepth 1 -name '[0-9]*' ! -name '0' ! -name '0.orig' \
        -printf '%f\n' 2>/dev/null | sort -n | tail -1
}

#------------------------------------------------------------------------------
# SETUP WRAPPER (comandi OF disponibili in PATH)
#------------------------------------------------------------------------------

echo "--- Setup: Creating OpenFOAM wrappers ---"
mkdir -p "$WRAPPER_DIR"

for cmd in blockMesh snappyHexMesh surfaceFeatureExtract checkMesh \
           decomposePar pimpleFoam simpleFoam reconstructPar \
           mapFields topoSet extrudeMesh createPatch; do
    cat > "$WRAPPER_DIR/$cmd" << WRAPPER
#!/bin/bash
apptainer exec "$CONTAINER_ABS" /bin/bash -c "source /opt/openfoam7/etc/bashrc && $cmd \$*"
WRAPPER
    chmod +x "$WRAPPER_DIR/$cmd"
done

export PATH="$WRAPPER_DIR:$PATH"

#------------------------------------------------------------------------------
# Stage 1 — snappyHexMesh (SKIP se mesh già presente in rans_baseline)
#------------------------------------------------------------------------------

echo ""
echo "====== Stage 1: snappyHexMesh ======"

RANS_MESH="$WORKDIR/rans_baseline/constant/polyMesh/points"
if [ -f "$RANS_MESH" ]; then
    echo ">>> SKIP: mesh già presente in rans_baseline/constant/polyMesh"
else
    echo ">>> Mesh non trovata, eseguo snappyHexMesh..."
    (
        cd "$WORKDIR/mesh_baseline" || exit 1
        runApplication blockMesh
        runApplication surfaceFeatureExtract
        runApplication snappyHexMesh -overwrite
        runApplication checkMesh -latestTime
        # Copia polyMesh in rans_baseline
        mkdir -p "$WORKDIR/rans_baseline/constant/polyMesh"
        cp -r constant/polyMesh/* "$WORKDIR/rans_baseline/constant/polyMesh/"
        echo ">>> Mesh copiata in rans_baseline/constant/polyMesh"
    )
fi

#------------------------------------------------------------------------------
# Stage 2 — simpleFoam (SKIP se latestTime > 0 trovato in rans_baseline)
#------------------------------------------------------------------------------

echo ""
echo "====== Stage 2: simpleFoam (rans_baseline) ======"

LATEST=$(latestTime "$WORKDIR/rans_baseline")

if [ -n "$LATEST" ]; then
    echo ">>> SKIP: soluzione trovata in rans_baseline/$LATEST"
else
    echo ">>> Nessuna soluzione trovata, eseguo simpleFoam..."
    (
        cd "$WORKDIR/rans_baseline" || exit 1
        rm -rf 0
        cp -r 0.orig 0
        runApplication simpleFoam
        LATEST=$(latestTime .)
        echo ">>> simpleFoam completato. LatestTime: $LATEST"
    )
fi

RANS_LATEST=$(latestTime "$WORKDIR/rans_baseline")
if [ -z "$RANS_LATEST" ]; then
    echo "ERRORE: simpleFoam non ha prodotto soluzioni. Controlla log.simpleFoam"
    exit 1
fi
echo ">>> Source per mapFields: rans_baseline/$RANS_LATEST"

#------------------------------------------------------------------------------
# Stage 3 — mapFields + topoSet + co-simulazione Python (cosim_main)
#------------------------------------------------------------------------------

echo ""
echo "====== Stage 3: Co-simulation (pimpleFoam + Python) ======"
(
    cd "$WORKDIR/cosim_main" || exit 1

    # Reset solo se fresh start
    if [ ! -f cosim_state.json ]; then
        rm -rf processor* log.* 2>/dev/null || true
        rm -rf 0 2>/dev/null || true
    fi

    # Condizioni iniziali
    cp -r 0.orig 0

    # Mappa soluzione stazionaria come IC
    echo "--- Running mapFields ---"
    apptainer exec "$CONTAINER_ABS" /bin/bash -c \
        "source /opt/openfoam7/etc/bashrc && \
         cd '$WORKDIR/cosim_main' && \
         mapFields '$WORKDIR/rans_baseline' -sourceTime latestTime -consistent" \
        2>&1 | tee log.mapFields

    # Zone di movimento
    runApplication topoSet

    # Rinomina pointDisplacement se necessario
    if [ -f 0/pointDisplacement.unmapped ]; then
        mv -f 0/pointDisplacement.unmapped 0/pointDisplacement
        echo ">>> Rinominato: pointDisplacement.unmapped → pointDisplacement"
    fi

    # Driver Python
    echo ">>> Avvio co-simulazione..."
    if [ -f cosim_state.json ]; then
        echo '>>> Restart detectato: riprendendo da stato salvato...'
        RESTART_FLAG='--restart'
    else
        RESTART_FLAG=''
    fi

    source /software/spack/share/spack/setup-env.sh
    source "$WORKDIR/my_venv/bin/activate"

    python3 cosim_driver.py --np 16 --window 200 --t-end 1.0 $RESTART_FLAG \
        2>&1 | tee log.cosim_driver
)

#------------------------------------------------------------------------------
# Stage 4 — Post-processing
#------------------------------------------------------------------------------

echo ""
echo "====== Stage 4: Post-processing ======"
(
    cd "$WORKDIR/cosim_main" || exit 1
    echo ">>> Running final reconstructPar..."
    apptainer exec "$CONTAINER_ABS" /bin/bash -c \
        "source /opt/openfoam7/etc/bashrc && cd '$WORKDIR/cosim_main' && reconstructPar" \
        2>&1 | tee log.reconstructPar
)

echo ""
echo "====== All stages complete. ======"
