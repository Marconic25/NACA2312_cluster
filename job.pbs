#!/bin/bash
#PBS -N NACA2312_RUN
#PBS -q cpu
#PBS -l select=1:ncpus=8:mpiprocs=8
#PBS -l walltime=04:00:00

# Entra nella cartella in /work dove hai i file
cd $PBS_O_WORKDIR

# Assicurati che Allrun sia eseguibile
chmod +x Allrun

# Lancia Allrun usando Apptainer
apptainer exec /software/containers/openfoam-2406.sif ./Allrun
